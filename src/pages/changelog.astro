---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import ChangelogEntry from "../components/ChangelogEntry.astro";

const parseDate = (value: unknown) => {
  if (!value) return 0;
  const date = value instanceof Date ? value : new Date(String(value));
  return Number.isNaN(date.getTime()) ? 0 : date.getTime();
};

// Import changelog entries
const changelogEntries = (await getCollection("changelog")).sort(
  (a, b) => parseDate(b.data.date) - parseDate(a.data.date)
);
---

<BaseLayout title="Changelog | My Portfolio">
  <section class="changelog-section">
    <div class="container">
      <div class="timeline">
        {changelogEntries.map((entry) => (
          <ChangelogEntry entry={entry} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .changelog-section {
    min-height: 100vh;
    padding: 8rem 1.5rem 4rem;
    position: relative;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
  }

  .timeline {
    position: relative;
    padding-left: 2rem;
    padding-top: 0.5rem;
  }

  .timeline::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(
      to bottom,
      var(--primary-accent),
      var(--secondary-accent)
    );
    opacity: 0.3;
  }

  :global(.changelog-entry) {
    position: relative;
    display: grid;
    gap: 1rem;
    padding: 2rem;
    margin-bottom: 3rem;
    background: rgba(var(--primary-bg-rgb), 0.6);
    border: 1px solid rgba(var(--primary-accent-rgb), 0.2);
    border-radius: 20px;
    backdrop-filter: blur(10px);
    transition: all 0.3s ease;
    animation: fadeInUp 0.8s ease-out backwards;
  }

  :global(.changelog-entry)::before {
    content: "";
    position: absolute;
    left: -2.5rem;
    top: 2.5rem;
    width: 12px;
    height: 12px;
    background: var(--primary-accent);
    border: 3px solid var(--primary-bg);
    border-radius: 50%;
    box-shadow: 0 0 0 4px rgba(var(--primary-accent-rgb), 0.2);
  }

  :global(.changelog-entry:hover) {
    transform: translateX(8px);
    border-color: rgba(var(--primary-accent-rgb), 0.4);
    box-shadow: 0 10px 40px rgba(var(--primary-accent-rgb), 0.15);
  }

  :global(.entry-header) {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  :global(.entry-date) {
    font-size: 0.9rem;
    color: rgba(var(--text-dark-bg-rgb), 0.6);
    font-weight: 500;
  }

  :global(.version-badge) {
    padding: 0.4rem 0.8rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  :global(.version-badge.major) {
    background: rgba(var(--primary-accent-rgb), 0.2);
    border: 1px solid var(--primary-accent);
    color: var(--primary-accent);
  }

  :global(.version-badge.minor) {
    background: rgba(var(--secondary-accent-rgb), 0.2);
    border: 1px solid var(--secondary-accent);
    color: var(--secondary-accent);
  }

  :global(.version-badge.patch) {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: rgba(var(--text-dark-bg-rgb), 0.8);
  }

  :global(.entry-title) {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-dark-bg);
    margin: 0;
  }

  :global(.entry-description) {
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(var(--text-dark-bg-rgb), 0.7);
    margin: 0;
  }

  :global(.entry-content) {
    display: grid;
    gap: 0.9rem;
    color: rgba(var(--text-dark-bg-rgb), 0.82);
    line-height: 1.7;
    margin: 0;
  }

  :global(.entry-content > *) {
    margin: 0;
  }

  :global(.entry-content a) {
    color: var(--secondary-accent);
  }

  :global(.entry-content strong) {
    color: var(--text-dark-bg);
  }

  :global(.entry-content ul),
  :global(.entry-content ol) {
    padding-left: 1.25rem;
  }

  :global(.entry-content li + li) {
    margin-top: 0.35rem;
  }

  :global(.entry-content h1),
  :global(.entry-content h2),
  :global(.entry-content h3),
  :global(.entry-content h4) {
    color: var(--text-dark-bg);
    line-height: 1.2;
  }

  :global(.entry-content p) {
    line-height: 1.75;
  }

  :global(.entry-content code) {
    background: rgba(var(--primary-accent-rgb), 0.1);
    padding: 0.15rem 0.4rem;
    border-radius: 0.35rem;
  }

  :global(.entry-content pre) {
    background: rgba(var(--primary-bg-rgb), 0.72);
    border: 1px solid rgba(var(--primary-accent-rgb), 0.12);
    padding: 1rem;
    border-radius: 0.9rem;
    overflow-x: auto;
  }

  :global(.changes-grid) {
    display: grid;
    gap: 1.5rem;
  }

  :global(.change-category) {
    padding: 1rem;
    border-radius: 10px;
    border-left: 3px solid;
  }

  :global(.change-category.added) {
    background: rgba(52, 211, 153, 0.05);
    border-left-color: #34d399;
  }

  :global(.change-category.improved) {
    background: rgba(96, 165, 250, 0.05);
    border-left-color: #60a5fa;
  }

  :global(.change-category.fixed) {
    background: rgba(251, 191, 36, 0.05);
    border-left-color: #fbbf24;
  }

  :global(.change-category.removed) {
    background: rgba(248, 113, 113, 0.05);
    border-left-color: #f87171;
  }

  :global(.category-title) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-dark-bg);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  :global(.category-icon) {
    font-size: 1.1rem;
  }

  :global(.change-list) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  :global(.change-list li) {
    padding-left: 1.5rem;
    position: relative;
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgba(var(--text-dark-bg-rgb), 0.8);
  }

  :global(.change-list li::before) {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--primary-accent);
    font-weight: 600;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .changelog-section {
      padding: 6rem 1rem 3rem;
    }

    .timeline {
      padding-left: 1.5rem;
    }

    :global(.changelog-entry) {
      padding: 1.5rem;
    }

    :global(.changelog-entry)::before {
      left: -2rem;
    }

    :global(.entry-title) {
      font-size: 1.25rem;
    }

    :global(.changes-grid) {
      gap: 1rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.changelog-entry) {
      animation: none;
    }

    :global(.changelog-entry:hover) {
      transform: none;
    }
  }
</style>
