<script>
  import {
    initializeFirebaseAnalytics,
    trackSitePageViewed,
  } from "../utils/firebaseAnalytics";

  const bootAnalytics = () => {
    void initializeFirebaseAnalytics();
    void trackSitePageViewed();
  };

  bootAnalytics();
  document.addEventListener("astro:page-load", bootAnalytics);
</script>
